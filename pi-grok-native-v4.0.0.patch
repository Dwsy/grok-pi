+#[derive(Debug, Clone)]
+pub struct SpawnConfig {
+    pub program: String,
+    pub prefix_args: Vec<String>,
+    pub cwd: PathBuf,
+    pub pi_args: Vec<String>,
+}
+
+#[derive(Clone)]
+pub struct PiRpc {
+    writer: mpsc::UnboundedSender<Value>,
+    pending: Arc<Mutex<HashMap<String, oneshot::Sender<Result<Value, String>>>>>,
+    next_id: Arc<AtomicU64>,
