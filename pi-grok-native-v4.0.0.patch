+        let pending_exit = pending.clone();
+        tokio::spawn(async move {
+            let message = match child.wait().await {
+                Ok(status) => format!("Pi RPC process exited with {status}"),
+                Err(error) => format!("failed waiting for Pi RPC process: {error}"),
+            };
