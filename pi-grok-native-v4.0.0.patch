+        nonlocal next_id
+        request_id = f"contract-{next_id}"
+        next_id += 1
+        value = {"id": request_id, "type": kind, **payload}
+        proc.stdin.write(json.dumps(value, separators=(",", ":")) + "\n")
+        proc.stdin.flush()
+        return request_id
+
+    def send_ui_response(event: dict[str, Any]) -> None:
+        method = event["method"]
