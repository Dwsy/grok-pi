+            if let Err(error) = self.handle_event(event).await {
+                tracing::warn!(%error, "failed to adapt Pi event into Grok ACP");
+                self.send_ui_notification(&format!("Pi adapter: {error}"), Some("warning"))
+                    .await;
+            }
