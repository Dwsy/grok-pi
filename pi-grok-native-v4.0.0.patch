+                    Ok(line) => line,
+                    Err(error) => {
+                        tracing::error!(%error, "failed to serialize Pi RPC command");
+                        continue;
+                    }
+                };
+                if stdin.write_all(&line).await.is_err()
+                    || stdin.write_all(b"\n").await.is_err()
+                    || stdin.flush().await.is_err()
